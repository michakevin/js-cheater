{
  "name": "js-cheater",
  "version": "0.1.0",
  "description": "Cheat-Engine-ähnlicher Scanner für Browser-RPGs (Manifest V3, keine Frameworks im Popup)",
  "private": true,
  "scripts": {
    "lint": "eslint src/**/*.js",
    "format": "prettier --write .",
    "check:ai-instructions": "node scripts/check-ai-instructions.mjs",
    "build": "node scripts/build-scanner.mjs",
    "dev": "node scripts/dev-server.mjs",
    "use:firefox": "node scripts/use-manifest.mjs firefox",
    "use:chrome": "node scripts/use-manifest.mjs chrome",
    "build:extensions": "node scripts/build-extensions.mjs",
    "test": "npm run build && jest",
    "test:unit": "npm run build && jest",
    "test:e2e": "npm run build && playwright test",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "setup": "npm install && npx playwright install"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.27.2",
    "babel-jest": "^30.2.0",
    "eslint": "^9.28.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "glob": "^13.0.3",
    "test-exclude": "^7.0.1"
  },
  "type": "module"
}
